# =============================================================================
# MyApi — Smoke Harness Env Template
# =============================================================================
#
# Usage
# -----
#   cp .env.smoke.example .env.smoke
#   # .env.smoke is git-ignored (see .gitignore rule `.env.smoke`)
#   npm run docker:smoke
#
# The values below are intentionally LONG, RANDOM-LOOKING, and NOT on the
# banned-defaults list enforced by `src/lib/validate-secrets.js`. They are
# NOT production-safe — the point is to let the secret validator pass so
# the app boots, and to give you a reproducible local environment.
#
# To generate real secrets (for anything other than this smoke harness):
#   openssl rand -hex 32                # JWT_SECRET, SESSION_SECRET, ENCRYPTION_KEY (as 32 bytes hex)
#   openssl rand -base64 32             # VAULT_KEY
#
# =============================================================================

# --- Core -------------------------------------------------------------------
NODE_ENV=development
PORT=4500
LOG_LEVEL=debug

# --- Database --------------------------------------------------------------
# Resolved inside the container — host `./data/` is bind-mounted here.
DB_PATH=/app/data/myapi.db

# --- Secrets (smoke-only; regenerate for anything non-local) ---------------
# 64 hex chars each for JWT / SESSION / ENCRYPTION; 44 chars base64 for VAULT.
JWT_SECRET=smoke_jwt_b6b8c1e2a3d4f5069788a9b0c1d2e3f4051627384950617283940a1b2c3d4e5f6
SESSION_SECRET=smoke_sess_94aa7b6c5d4e3f2a19283746556473829100fedcba9876543210abcdef012345
ENCRYPTION_KEY=smoke_enc_key_0123456789abcdef01
VAULT_KEY=c21va2VWYXVsdEtleUZvckxvY2FsRG9ja2VyU21va2VUZXN0aW5nT25seQ==

# Set to true only if you terminate HTTPS in front of the container.
SESSION_COOKIE_SECURE=false

# --- URLs & CORS -----------------------------------------------------------
BASE_URL=http://localhost:4500
PUBLIC_URL=http://localhost:4500
ALLOWED_ORIGINS=http://localhost:4500,http://localhost:5173

# --- User identity ---------------------------------------------------------
POWER_USER_EMAIL=owner@example.com

# --- Rate limiting ---------------------------------------------------------
# Higher than production so curling in a loop doesn't trip the limiter.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# --- OAuth provider flags --------------------------------------------------
# Leave all off by default — flip the ones you actually want to smoke-test
# after filling in their client credentials below.
ENABLE_OAUTH_GOOGLE=false
ENABLE_OAUTH_GITHUB=false
ENABLE_OAUTH_DISCORD=false
ENABLE_OAUTH_SLACK=false

# --- OAuth credentials (fill only for enabled services) --------------------
# NOTE: redirect URIs must be registered with each provider's console and
# must match exactly. For pure smoke testing of the new M3 state-token
# machinery (once Steps 4+5 land), you can point at mock providers or
# just assert the authorize 302 + DB row without completing the upstream
# flow.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/google

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/github

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/discord

SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:4500/api/v1/oauth/callback/slack
