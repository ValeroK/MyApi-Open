{
  "name": "MyApi",
  "version": "1.0.0",
  "description": "Self-hosted Personal API for AI Agents",
  "repository": {
    "type": "git",
    "url": "https://github.com/omribenami/MyApi-Open"
  },
  "scripts": {
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --detectOpenHandles --forceExit src/tests/integration.test.js src/tests/security-regression.test.js src/tests/scope-isolation.test.js src/tests/token-update.test.js src/tests/phase3.audit-security.test.js src/tests/phase2-billing.test.js src/tests/beta-mode.test.js",
    "test:oauth": "jest --detectOpenHandles --forceExit src/tests/oauth-state-domain.test.js src/tests/oauth-state-schema.test.js src/tests/oauth-state-inventory.test.js src/tests/oauth-security-hardening.test.js src/tests/oauth-signup-flow.test.js",
    "dev": "cd src && npx nodemon index.js",
    "start": "node src/index.js",
    "start:prod": "NODE_ENV=production node src/index.js",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "eslint \"src/**/*.{js,ts}\" \"scripts/**/*.js\"",
    "lint:backend:fix": "eslint \"src/**/*.{js,ts}\" \"scripts/**/*.js\" --fix",
    "lint:frontend": "npm run lint --prefix src/public/dashboard-app",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,ts,jsx,tsx,json,md,yml,yaml}\"",
    "build:frontend": "cd src/public/dashboard-app && npm run build",
    "dashboard:install": "npm install --prefix src/public/dashboard-app",
    "dashboard:build": "npm run build --prefix src/public/dashboard-app",
    "dashboard:rebuild": "npm run dashboard:install && npm run dashboard:build",
    "build:docker": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:test": "docker-compose -f docker-compose.test.yml up --build --abort-on-container-exit --exit-code-from myapi-test",
    "docker:test:integration": "docker-compose -f docker-compose.test.yml run --rm --build myapi-test npm run test:integration",
    "docker:test:oauth": "docker-compose -f docker-compose.test.yml run --rm --build myapi-test npm run test:oauth",
    "docker:smoke": "docker-compose -f docker-compose.smoke.yml up -d --build",
    "docker:smoke:down": "docker-compose -f docker-compose.smoke.yml down",
    "docker:smoke:logs": "docker-compose -f docker-compose.smoke.yml logs -f myapi-smoke",
    "docker:smoke:shell": "docker exec -it myapi-smoke sh",
    "docker:smoke:init": "docker exec -it myapi-smoke node src/scripts/init-db.js",
    "smoke:oauth": "jest --forceExit src/tests/oauth-authorize-url-live-smoke.test.js",
    "db:init": "node src/scripts/init-db.js",
    "db:migrate": "node src/scripts/migrate.js run",
    "db:migrate:status": "node src/scripts/migrate.js status",
    "db:migrate:rollback": "node src/scripts/migrate.js rollback",
    "db:migrate:create": "node src/scripts/migrate.js create",
    "backup:create": "node src/scripts/backup.js create",
    "backup:restore": "node src/scripts/backup.js restore",
    "backup:list": "node src/scripts/backup.js list",
    "backup:status": "node src/scripts/backup.js status",
    "tenant:create": "node src/scripts/tenant.js create",
    "tenant:list": "node src/scripts/tenant.js list",
    "ssl:setup": "bash scripts/setup-ssl.sh setup",
    "ssl:status": "bash scripts/setup-ssl.sh status",
    "ssl:renew": "bash scripts/setup-ssl.sh renew",
    "ssl:self-signed": "bash scripts/setup-ssl.sh self-signed"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "better-sqlite3-session-store": "^0.1.0",
    "cors": "^2.8.6",
    "deasync": "^0.1.31",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "marked": "^14.1.4",
    "mongodb": "^6.3.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "stripe": "^20.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n": "^17.15.1",
    "eslint-plugin-security": "^3.0.1",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "supertest": "^7.2.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
